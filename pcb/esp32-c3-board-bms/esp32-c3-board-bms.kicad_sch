	(text "VOut = 0.925 * (R1+R8+R2)/R2\n0.912*(26.1+5.23)/5.23=5.46V\n0.912*(47+10)/10=5.19V   <<<< no diode\n0.912*(47+1+10)/10=5.28V\n0.912*(47+2.2+10)/10=5.39\n0.912*(47+3.3+10)/10=5.49\n0.912*(47+4.7+10)/10=5.62\n0.912*(47+10+10)/10=5.62"
		(exclude_from_sim no)
		(at 184.912 67.056 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "1c6d647c-3401-4e79-ad1d-8cd55b0158ad")
	)
