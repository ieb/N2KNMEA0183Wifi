	(text "The ESP32 is powered from the BMS.\nIt senses the CAN bus being enabled when CAN-SENSE is pulled low by the opto-isolator\nand starts the can bus when this happens becomming live which means it will enable\nWifi and the CAN\n\nWhen the CAN bus is not live, it will run with only BLE enabled"
		(exclude_from_sim no)
		(at 21.336 88.9 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d5b90d1b-2c28-485b-ba1d-b23f9da58e68")
	)
