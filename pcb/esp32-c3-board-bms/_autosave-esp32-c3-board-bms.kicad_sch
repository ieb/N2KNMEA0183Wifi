	(text "Isolated to BMS"
		(exclude_from_sim no)
		(at 206.4512 114.046 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "8207cbb0-8234-4763-b3b7-5a8edb4f45b0")
	)
	(text "The ESP32 is powered from the BMS.\nIt senses the CAN bus beign enabled on a pin\nand starts the can bus when this happens becomming live which means it will enable\nWifi and the CAN\n\nWhen the CAN bus is not live, it will run with only BLE enabled and will idelly\nonly power that up preiodically to detect if a client is scanning."
		(exclude_from_sim no)
		(at 56.642 113.284 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d5b90d1b-2c28-485b-ba1d-b23f9da58e68")
	)
